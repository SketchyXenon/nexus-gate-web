# =====================================================================
# Nexus Gate — Example Environment Variables
# ---------------------------------------------------------------------
# Copy this file to .env and fill in your values.
# Generate secrets: openssl rand -base64 32
# =====================================================================

# ---------------------------------------------------------------------
# Database (PostgreSQL via Supabase — REQUIRED for production)
# ---------------------------------------------------------------------
# Get these from Supabase Dashboard → Settings → Database → Connection string
# Transaction URL (port 6543, for the app — uses PgBouncer pooling):
DATABASE_URL="postgresql://postgres.[REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&pool_timeout=20"
# Session URL (port 5432, for Prisma migrations):
DIRECT_URL="postgresql://postgres.[REF]:[PASSWORD]@aws-0-[REGION].supabase.com:5432/postgres"

# ---------------------------------------------------------------------
# Auth secrets (REQUIRED — generate with: openssl rand -base64 32)
# Used for legacy JWT signing helpers in src/lib/auth.ts (HMAC).
# Supabase Auth handles sessions, passwords, and email flows.
# ---------------------------------------------------------------------
AUTH_SECRET="replace-with-random-32-byte-secret"
REFRESH_SECRET="replace-with-different-random-32-byte-secret"

# ---------------------------------------------------------------------
# App URL (used in email redirects, magic links, CSRF origin check)
# ---------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ---------------------------------------------------------------------
# Supabase (REQUIRED for production — get from Supabase Dashboard)
# ---------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# ---------------------------------------------------------------------
# Rate limiting (optional — falls back to in-memory if not set)
# ---------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ---------------------------------------------------------------------
# Email (Gmail SMTP — optional, required for forgot-password)
# ---------------------------------------------------------------------
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""
SMTP_FROM_NAME="Nexus Gate"

# ---------------------------------------------------------------------
# Realtime (Ably — free tier: 3M messages/mo, 200 connections)
# ---------------------------------------------------------------------
# Get the key from: https://ably.com/dashboard -> your app -> API Keys
# Format: keyName:keySecret (e.g. appId.keyId:secret). Copy the FULL key.
# This is the ONLY Ably env var needed — the browser uses token auth via
# /api/ably/token (signed server-side). Do NOT set NEXT_PUBLIC_ABLY_KEY.
ABLY_SERVER_KEY=""

# ---------------------------------------------------------------------
# Error monitoring (optional)
# ---------------------------------------------------------------------
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""

# ---------------------------------------------------------------------
# Cloudflare Turnstile (optional — bot protection)
# ---------------------------------------------------------------------
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# ---------------------------------------------------------------------
# Cron secret (REQUIRED in production — protects /api/cron/* endpoints)
# ---------------------------------------------------------------------
CRON_SECRET="replace-with-random-32-byte-secret"

# ---------------------------------------------------------------------
# Bootstrap admin (used by scripts/bootstrap-admin.ts — optional)
# ---------------------------------------------------------------------
# BOOTSTRAP_ADMIN_EMAIL="admin@yourschool.edu"
# BOOTSTRAP_ADMIN_PASSWORD="StrongPassword123!"
# BOOTSTRAP_ADMIN_NAME="System Administrator"

# ---------------------------------------------------------------------
# Performance optimizations (optional)
# ---------------------------------------------------------------------
# JWT local validation: eliminates the supabase.auth.getUser() network
# round-trip on every authed request (saves 50-150ms). Get the secret
# from Supabase Dashboard > Project Settings > API > JWT Secret.
# SUPABASE_JWT_SECRET=""

# Read replica: routes dashboard/stats heavy reads to a Supabase read
# replica to offload the primary DB. Leave empty to use the primary.
# DATABASE_REPLICA_URL=""
