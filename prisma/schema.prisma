// ====================================================================
// Nexus Gate — Production Schema (v7 — strict RLS-ready, optimized indexes)
// ====================================================================
// Indexing strategy:
//   - Composite indexes on the most common query patterns
//   - Covering indexes for list + count queries (status + program + section)
//   - Partial-style filtering via leading columns (status first, then scope)
// ====================================================================
//
// IMPORTANT — Provider is PostgreSQL.
// The app deploys to Vercel (serverless) and uses Supabase (PostgreSQL 15+).
// SQLite CANNOT be used on Vercel serverless (ephemeral, read-only FS), so
// the provider MUST be "postgresql" in production. The Supabase schema is
// created by the SQL migrations in /supabase/migrations (snake_case table
// and column names). The @map / @@map directives below bridge Prisma's
// camelCase field names to those snake_case database identifiers.
// ====================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ====================================================================
// 1. ACCOUNTS
// ====================================================================

model Account {
  id              String        @id @default(cuid())
  email           String        @unique
  passwordHash    String        @default("") @map("password_hash")
  fullName        String        @map("full_name")
  role            String        @default("USER")
  status          String        @default("PENDING_VERIFICATION")
  studentId       Int?          @unique @map("student_id")
  program         String?
  section         String?
  authProvider    String?       @map("auth_provider")
  providerAccountId String?     @map("provider_account_id")
  year            Int?
  organizationName String?      @map("organization_name")
  courseModifiedAt DateTime?    @map("course_modified_at")
  lastProfileUpdateAt DateTime? @map("last_profile_update_at")
  lastPasswordChangeAt DateTime? @map("last_password_change_at")
  notificationEndpoint String?  @map("notification_endpoint")
  notificationKeys     String?  @map("notification_keys")
  passkeyCredential    String?  @map("passkey_credential")
  passkeyCredentialId  String?  @map("passkey_credential_id")
  supabaseAuthUid      String?  @unique @map("supabase_auth_uid")
  notificationEnabled  Boolean  @default(false) @map("notification_enabled")
  notificationPrefs    Json?    @map("notification_prefs")
  lastLoginAt     DateTime?     @map("last_login_at")
  failedLoginAttempts Int       @default(0) @map("failed_login_attempts")
  lockedUntil     DateTime?     @map("locked_until")
  // Email verification timestamp (set when user clicks the verification link).
  emailVerifiedAt DateTime?     @map("email_verified_at")
  // Soft-delete / deactivation fields (never hard-delete user data).
  isDeactivated   Boolean       @default(false) @map("is_deactivated")
  deactivatedAt   DateTime?     @map("deactivated_at")
  deactivatedReason String?     @map("deactivated_reason")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  eventsOwned       Event[]
  attendances       EventAttendance[]
  overridesMade     AttendanceOverride[]
  notifications     Notification[]
  auditLogs         AuditLog[]
  verificationTokens VerificationToken[]
  refreshTokens     RefreshToken[]
  deviceKeys        DeviceKey[]
  termsAcceptances  TermsAcceptance[]

  // ---- High-quality indexes ----
  // Role + status: admin dashboard lists accounts by role/status frequently
  @@index([role, status])
  // Program + section: event eligibility checks filter by program/section
  @@index([program, section])
  // Notification push lookups
  @@index([notificationEnabled])
  // Login security: locked account sweep + brute-force detection
  @@index([lockedUntil])
  // Soft activity sort
  @@index([lastLoginAt])
  // Passkey login: O(log N) lookup by credential ID (replaces N-row scan)
  @@index([passkeyCredentialId])
  // Admin roster sort
  @@index([createdAt])
  // Deactivation filter: list active accounts excluding soft-deleted
  @@index([isDeactivated])

  @@map("accounts")
}

// ====================================================================
// 2. AUTHORIZED STUDENTS — optional admin whitelist (not a gate)
// ====================================================================

model AuthorizedStudent {
  studentId   Int      @id @map("student_id")
  email       String   @unique
  fullName    String   @map("full_name")
  program     String
  section     String
  activated   Boolean  @default(false)
  overrides   AttendanceOverride[]

  // Composite: whitelist listing filtered by program+section, then activation
  @@index([program, section, activated])
  // Activation sweep (admin dashboard "pending activation" view)
  @@index([activated])

  @@map("authorized_students")
}

// ====================================================================
// 3. VERIFICATION TOKENS
// ====================================================================

model VerificationToken {
  id        String   @id @default(cuid())
  accountId String   @map("account_id")
  account   Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  codeHash  String   @map("code_hash")
  purpose   String
  expiresAt DateTime @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime @default(now()) @map("created_at")
  attempts  Int      @default(0)

  // Composite: "find an unused, non-expired token for this account+purpose"
  @@index([accountId, purpose, usedAt])
  // Cron sweep: delete expired tokens
  @@index([expiresAt])

  @@map("verification_tokens")
}

// ====================================================================
// 4. REFRESH TOKENS
// ====================================================================

model RefreshToken {
  id        String    @id @default(cuid())
  accountId String    @map("account_id")
  account   Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  // Composite: "find active tokens for an account" (revokedAt IS NULL)
  @@index([accountId, revokedAt])
  // Cron sweep: delete expired tokens
  @@index([expiresAt])

  @@map("refresh_tokens")
}

// ====================================================================
// 5. EVENTS
// ====================================================================

model Event {
  id            Int       @id @default(autoincrement())
  title         String
  description   String?
  eventSecret   String    @default(cuid()) @map("event_secret")
  ownerId       String    @map("owner_id")
  owner         Account   @relation(fields: [ownerId], references: [id], onDelete: Restrict)
  scope         String    @default("academic")
  targetProgram String?   @map("target_program")
  targetSection String?   @map("target_section")
  scheduledAt   DateTime  @map("scheduled_at")
  endsAt        DateTime? @map("ends_at")
  checkInOpensAt   DateTime? @map("check_in_opens_at")
  checkInClosesAt  DateTime? @map("check_in_closes_at")
  timeOutOpensAt   DateTime? @map("time_out_opens_at")
  timeOutClosesAt  DateTime? @map("time_out_closes_at")
  enableTimeOut    Boolean   @default(false) @map("enable_time_out")
  delegatable      Boolean   @default(true)
  // Admin-controlled flag: when true, allows OTHER organizers to project
  // this event's QR code IF they share the same organizationName tag as
  // the event owner, OR if the event is open-to-all.
  delegationEnabled Boolean  @default(false) @map("delegation_enabled")
  status        String    @default("active")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  attendances EventAttendance[]
  overrides   AttendanceOverride[]

  // ---- High-quality indexes ----
  // The MAIN eligibility query: WHERE status='active' AND (
  //   (targetProgram IS NULL AND targetSection IS NULL) OR
  //   (targetProgram = ? AND targetSection = ?)
  // ) ORDER BY scheduledAt DESC
  // This composite index covers the most common listing path.
  @@index([status, scheduledAt])
  // Organizer dashboard: list my events
  @@index([ownerId, status])
  // Organizer dashboard sorted view (ownerId + status + scheduledAt)
  @@index([ownerId, status, scheduledAt])
  // Strict eligibility: filter by exact program+section match
  @@index([targetProgram, targetSection, status])
  // Cron reminders: upcoming events by scheduled time
  @@index([scheduledAt, status])

  @@map("events")
}

// ====================================================================
// 6. EVENT ATTENDANCE
// --------------------------------------------------------------------
// Certificate fields (v8 — Tier 1 + Tier 2 anti-cheating):
//   certificateNonce     — one-time-use nonce from the scan certificate
//                          (unique constraint = atomic duplicate rejection)
//   certificateSubFrames — JSON array of captured sub-frame indices
//                          (proves multi-frame liveness, anti-screenshot)
//   deviceFingerprint    — SHA-256 hash of the device's public key
//                          (identifies which device made the scan)
//   scannedAtClient      — client-reported scan timestamp (ms precision)
//                          (decouples token validity from sync time)
// ====================================================================

model EventAttendance {
  id             Int      @id @default(autoincrement())
  eventId        Int      @map("event_id")
  event          Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  accountId      String   @map("account_id")
  account        Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  scannedAt      DateTime @default(now()) @map("scanned_at")
  timeOutAt      DateTime? @map("time_out_at")
  source         String   @default("qr")
  idempotencyKey String?  @unique @map("idempotency_key")
  tokenBlock     Int?     @map("token_block")

  // ---- Certificate fields (v8 anti-cheating) ----
  certificateNonce     String?  @unique @map("certificate_nonce")
  certificateSubFrames String?  @map("certificate_sub_frames") // JSON array, e.g. "[0,1,2]"
  deviceFingerprint    String?  @map("device_fingerprint")
  scannedAtClient      DateTime? @map("scanned_at_client") // client-reported scan time (for offline sync)

  // Unique constraint: one check-in per (event, account) pair — atomic.
  // This is the CORE of the one-attempt policy: after the first successful
  // scan, the unique constraint rejects all subsequent attempts.
  @@unique([eventId, accountId])
  // Composite: "list this student's attendance history, newest first"
  @@index([accountId, scannedAt])
  // Composite: "count attendance for an event" (dashboard stats)
  @@index([eventId, scannedAt])
  // Cron sweep / analytics by scan time
  @@index([scannedAt])
  // Device audit: "list all scans from this device"
  @@index([deviceFingerprint])

  @@map("event_attendance")
}

// ====================================================================
// 7. ATTENDANCE OVERRIDES
// ====================================================================

model AttendanceOverride {
  id          Int      @id @default(autoincrement())
  eventId     Int      @map("event_id")
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  adminId     String   @map("admin_id")
  admin       Account  @relation(fields: [adminId], references: [id], onDelete: Cascade)
  studentId   Int      @map("student_id")
  student     AuthorizedStudent @relation(fields: [studentId], references: [studentId], onDelete: Cascade)
  reason      String
  createdAt   DateTime @default(now()) @map("created_at")

  // Composite: list overrides for an event (newest first)
  @@index([eventId, createdAt])
  // Admin audit: list overrides made by an admin
  @@index([adminId, createdAt])
  // IDEMPOTENCY: prevents duplicate override records on retry
  @@unique([eventId, studentId])

  @@map("attendance_overrides")
}

// ====================================================================
// 8. NOTIFICATIONS
// ====================================================================

model Notification {
  id          Int      @id @default(autoincrement())
  accountId   String   @map("account_id")
  account     Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  title       String
  body        String
  type        String   @default("info")
  readAt      DateTime? @map("read_at")
  createdAt   DateTime @default(now()) @map("created_at")

  // Composite: "list this account's notifications, newest first" — the
  // single most common notification query
  @@index([accountId, createdAt])
  // Composite: "count UNREAD notifications for this account" — used by
  // the notification bell badge on every page load
  @@index([accountId, readAt])
  // Cron sweep: delete old read notifications
  @@index([readAt, createdAt])
  // Cron event-reminders dedup: WHERE type LIKE 'reminder:event:%' AND created_at > X
  @@index([type, createdAt])

  @@map("notifications")
}

// ====================================================================
// 9. AUDIT LOG
// ====================================================================

model AuditLog {
  id         Int      @id @default(autoincrement())
  actorId    String?  @map("actor_id")
  actor      Account? @relation(fields: [actorId], references: [id], onDelete: SetNull)
  action     String
  targetType String?  @map("target_type")
  targetId   String?  @map("target_id")
  metadata   String?
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")

  // Composite: "list this actor's actions, newest first" (user activity)
  @@index([actorId, createdAt])
  // Composite: "filter audit log by action type, newest first" (admin view)
  @@index([action, createdAt])
  // Composite: "view audit history for this target entity, newest first"
  @@index([targetType, targetId, createdAt])
  // Cron sweep: delete old audit logs
  @@index([createdAt])

  @@map("audit_logs")
}

// ====================================================================
// 10. DEVICE KEYS (v8 — Tier 1 anti-cheating)
// --------------------------------------------------------------------
// Each registered device has an Ed25519 keypair. The PRIVATE key lives
// only on the device (IndexedDB). The PUBLIC key is registered here.
// Scan certificates are signed by the device's private key and verified
// against the public key stored here.
//
// A fingerprint (SHA-256 of the public key) is used for fast lookups
// and is also stored on each EventAttendance record for audit trails.
// ====================================================================

model DeviceKey {
  id           String    @id @default(cuid())
  accountId    String    @map("account_id")
  account      Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  publicKeyJwk String    @map("public_key_jwk") // Ed25519 public key as JSON Web Key (JSON string)
  fingerprint  String    @unique // SHA-256 hash of the public key (hex)
  label        String?   // optional device name (e.g. "iPhone 14")
  createdAt    DateTime  @default(now()) @map("created_at")
  lastUsedAt   DateTime? @map("last_used_at")
  revokedAt    DateTime? @map("revoked_at")

  // Composite: "list this account's registered devices"
  @@index([accountId, revokedAt])
  // Lookup by fingerprint (used during certificate verification)
  // fingerprint is already @unique so no separate index needed

  @@map("device_keys")
}

// ====================================================================
// 11. SETTINGS
// ====================================================================

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("settings")
}

// ====================================================================
// 12. TERMS ACCEPTANCES (immutable compliance record)
// --------------------------------------------------------------------
// Append-only table: every time a user accepts the Terms of Service and
// Privacy Policy, a row is inserted. Rows are never updated or deleted
// (immutable audit trail for legal compliance). If the Terms change,
// a new row is inserted with the updated version hash.
// ====================================================================

model TermsAcceptance {
  id          String   @id @default(cuid())
  accountId   String   @map("account_id")
  account     Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  // Semantic version of the Terms document the user agreed to.
  termsVersion String  @map("terms_version")
  // SHA-256 hash of the Terms document content at acceptance time.
  termsHash   String   @map("terms_hash")
  // Semantic version of the Privacy Policy document.
  policyVersion String @map("policy_version")
  policyHash  String   @map("policy_hash")
  // IP address and user agent for legal evidence.
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")
  acceptedAt  DateTime @default(now()) @map("accepted_at")

  // Lookup: "get all acceptances for this account" (compliance audit)
  @@index([accountId, acceptedAt])

  @@map("terms_acceptances")
}
